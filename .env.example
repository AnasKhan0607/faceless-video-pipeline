# Video Pipeline Environment Variables
# Copy this to .env and fill in your API keys

# === Required for video generation ===

# Fish.audio - Text-to-Speech
# Get your key at: https://fish.audio/
FISH_API_KEY=your_fish_audio_api_key_here

# Deepgram - Word-level timestamps
# Get your key at: https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# OpenAI - Script generation (GPT-4o)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# === Optional - Platform uploads ===

# Discord webhook for notifications
# Create in: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# === Notes ===
# - Never commit your .env file to git
# - Keep your API keys private
# - Rotate keys if accidentally exposed
